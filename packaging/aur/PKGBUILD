# Maintainer: Giuseppe Della Vedova <giuseppe@zerostack.dev>
# Upstream: https://github.com/gi-dellav/zerostack

pkgname=zerostack
pkgver=1.4.5
pkgrel=1
pkgdesc="Minimalistic coding agent written in Rust, optimized for memory footprint and performance"
arch=('x86_64' 'aarch64')
url="https://github.com/gi-dellav/zerostack"
license=('GPL-3.0-only')
makedepends=()

source_x86_64=(
    "${pkgname}-${pkgver}-x86_64.tar.gz::https://github.com/gi-dellav/zerostack/releases/download/v${pkgver}/zerostack-x86_64-unknown-linux-musl.tar.gz"
    "LICENSE::https://raw.githubusercontent.com/gi-dellav/zerostack/v${pkgver}/LICENSE"
)
source_aarch64=(
    "${pkgname}-${pkgver}-aarch64.tar.gz::https://github.com/gi-dellav/zerostack/releases/download/v${pkgver}/zerostack-aarch64-unknown-linux-musl.tar.gz"
    "LICENSE::https://raw.githubusercontent.com/gi-dellav/zerostack/v${pkgver}/LICENSE"
)

# SHA256 must be updated on each release — compute via:
#   curl -sL <url> | sha256sum
sha256sums_x86_64=('SKIP' 'SKIP')
sha256sums_aarch64=('SKIP' 'SKIP')

package() {
    cd "$srcdir"
    install -Dm755 "zerostack-${CARCH}-unknown-linux-musl" "${pkgdir}/usr/bin/zerostack"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
